# Copy this file to .env and fill in values before running docker-compose.

# ── Cognito ────────────────────────────────────────────────────────────────────
COGNITO_ISSUER_URI=https://cognito-idp.us-east-1.amazonaws.com/<user-pool-id>
COGNITO_JWKS_URI=https://cognito-idp.us-east-1.amazonaws.com/<user-pool-id>/.well-known/jwks.json
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=<app-client-id>
COGNITO_CLIENT_SECRET=                    # leave blank if client has no secret

# ── AWS credentials ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<access-key-id>
AWS_SECRET_ACCESS_KEY=<secret-access-key>

# ── Database (dev/prod only — local uses hardcoded defaults) ───────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://<rds-endpoint>:5432/identity_service
SPRING_DATASOURCE_USERNAME=identity_user
SPRING_DATASOURCE_PASSWORD=<db-password>

# ── Email (dev/prod only — local uses Mailhog) ─────────────────────────────────
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_USERNAME=<ses-smtp-username>
SES_PASSWORD=<ses-smtp-password>
EMAIL_FROM=noreply@yourdomain.com

# ── Docker image (dev docker-compose only) ─────────────────────────────────────
IMAGE_NAME=identity-service
IMAGE_TAG=latest
